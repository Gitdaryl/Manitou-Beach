# ============================================================
# Manitou Beach Community Platform — Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit .env — it contains secrets.

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Notion tokens (one per integration) ──────────────────────
NOTION_TOKEN_BUSINESS=ntn_...
NOTION_TOKEN_EVENTS=ntn_...
NOTION_TOKEN_DISPATCH=ntn_...
NOTION_TOKEN_HERO=ntn_...
NOTION_TOKEN_POIS=ntn_...

# ── Notion database IDs ──────────────────────────────────────
NOTION_DB_BUSINESS=
NOTION_DB_EVENTS=
NOTION_DB_POIS=
NOTION_DB_DISPATCH_ARTICLES=
NOTION_DB_DISPATCH_PROMOTIONS=
NOTION_DB_DISPATCH_ISSUES=
NOTION_DB_HERO=
NOTION_DB_CLAIMS=
NOTION_DB_PROMO_CLAIMS=
NOTION_DB_WEBSITE_INQUIRIES=
NOTION_DB_CONTACT=
NOTION_DB_STAYS=
NOTION_DB_TICKETS=

# ── Beehiiv (newsletter) ────────────────────────────────────
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_...

# ── ElevenLabs (voice concierge) ──────────────────────────────
# VITE_ELEVENLABS_AGENT_ID=

# ── Anthropic (QA agent) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Admin ────────────────────────────────────────────────────
ADMIN_SECRET=

# ── YouTube (Holly & The Yeti videos) ──────────────────────
YOUTUBE_API_KEY=

# ── Resend (email delivery) ──────────────────────────────────
RESEND_API_KEY=re_...

# ── Vercel cron auth ─────────────────────────────────────────
CRON_SECRET=
